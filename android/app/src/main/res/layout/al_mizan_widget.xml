<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- Header row: app name + streak -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Al Mizan"
            android:textColor="#4EDEA3"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fillo sot!"
            android:textColor="#4EDEA3"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="8dp"
        android:background="#334EDEA3" />

    <!-- Quote text -->
    <TextView
        android:id="@+id/widget_quote"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Mësoje edebin përpara diturisë."
        android:textColor="#E8F5F0"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"
        android:ellipsize="end"
        android:maxLines="3" />

    <!-- Author -->
    <TextView
        android:id="@+id/widget_author"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="— Imam Maliku"
        android:textColor="#7ABFA0"
        android:textSize="11sp"
        android:textStyle="italic" />

</LinearLayout>
